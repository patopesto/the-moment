# Copy this file to .env and adjust values for your environment.
# .env is gitignored — never commit it.

# ─── Timezone ─────────────────────────────────────────────────────────────────
#
# Set to your local timezone. Used by the Spoolman container for timestamps.
# Examples: America/New_York  America/Los_Angeles  Europe/London  Asia/Tokyo
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones

TZ=UTC

# ─── Ports ────────────────────────────────────────────────────────────────────

# Port The Moment listens on (host-side)
THE_MOMENT_PORT=5000

# Port Spoolman listens on (host-side)
SPOOLMAN_PORT=7912

# ─── Data directories (host paths) ───────────────────────────────────────────
#
# All services store data in host-filesystem directories (bind mounts), NOT
# anonymous Docker volumes. Backups are simple:
#   tar czf backup.tar.gz ./the-moment-data ./spoolman-data
#
# Paths can be relative (resolved from docker-compose.yml) or absolute
# (e.g. /mnt/nas/gcode). Docker creates directories automatically on first run.
#
# The Moment uses three separate paths so each can be relocated independently
# (e.g. gcode files on a large NAS volume, DB on fast local SSD).

# Host path for The Moment's SQLite database directory.
THE_MOMENT_DB_PATH=./the-moment-data/db

# Host path for print history file attachments (gcode, slicer files, etc.)
THE_MOMENT_GCODE_PATH=./the-moment-data/gcode

# Host path for virtual printer uploaded files.
THE_MOMENT_UPLOADS_PATH=./the-moment-data/uploads

# Host path for Spoolman's SQLite database.
SPOOLMAN_DB_PATH=./spoolman-data

# ─── Backups ──────────────────────────────────────────────────────────────────
#
# Directory where `make backup` writes timestamped archives.
# Point this at a network share or a path your backup agent already monitors.
# Archives are named: backup-YYYYMMDD-HHMMSS.tar.gz
# Restore with: make restore BACKUP=./backups/backup-YYYYMMDD-HHMMSS.tar.gz

BACKUP_DIR=./backups

# ─── Bambu printer debug logging ─────────────────────────────────────────────
#
# Set to 1 to enable verbose Bambu MQTT debug logging.
# Logs raw MQTT payloads, TLS handshake outcome, parsed status, and state
# machine transitions. Use this to capture a transcript when connecting a
# Bambu printer for the first time so any integration issues can be diagnosed.
#
# Collect logs with:  docker logs the-moment 2>&1 | grep "BAMBU"
#
# BAMBU_DEBUG=0
